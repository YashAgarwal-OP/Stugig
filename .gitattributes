# Normalize line endings to LF in the repo for all text files.
# This prevents the LF->CRLF warnings on Windows and keeps the
# repo consistent across macOS / Linux / Windows contributors.
* text=auto eol=lf

# Force binary files to be treated as binary (no line ending conversion)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
