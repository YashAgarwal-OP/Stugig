# ============================================================
# Client environment variables — copy to .env and fill in values
# NEVER commit .env — only commit this .env.example file
# ============================================================

# Stripe publishable key (starts with pk_test_ for sandbox, pk_live_ for production)
# This key is safe to expose in frontend code — it is NOT a secret.
# Get from: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Backend API URL — only required in production builds.
# Leave empty in development (Vite dev server proxy handles /api automatically).
# Example: https://stugig-backend.onrender.com
VITE_API_URL=
