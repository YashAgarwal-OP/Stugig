# =============================================================
# StuGig Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — only commit this .env.example file.
# =============================================================

# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────
# Local:      mongodb://localhost:27017/stugig
# Atlas:      mongodb+srv://<user>:<pass>@cluster.mongodb.net/stugig
MONGO_URI=mongodb://localhost:27017/stugig

# ── JSON Web Token ────────────────────────────────────────────
# Use a long random string in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_SECRET
JWT_EXPIRE=30d

# ── Stripe ────────────────────────────────────────────────────
# Sandbox keys from https://dashboard.stripe.com/test/apikeys
# Secret key starts with sk_test_ (never expose this in the frontend)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
# Webhook secret — from the Stripe CLI or Dashboard webhook configuration
# Run locally: stripe listen --forward-to localhost:5000/api/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Redirect URLs after checkout (must match your frontend URL)
STRIPE_SUCCESS_URL=http://localhost:5173/payment/success
STRIPE_CANCEL_URL=http://localhost:5173/payment/cancel

# ── Google Gemini AI ─────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# If not set, the AI features fall back to deterministic mock responses.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── CORS / Socket.io ─────────────────────────────────────────
# The URL of the frontend dev server (Vite default: 5173)
# In production set this to your deployed frontend domain.
CLIENT_URL=http://localhost:5173

# ── Email / SMTP ──────────────────────────────────────────────
# Supports any SMTP provider. Examples:
#
#   SendGrid:   HOST=smtp.sendgrid.net  PORT=587  USER=apikey  PASS=<SG.xxxxx>
#   Resend:     HOST=smtp.resend.com    PORT=465  USER=resend   PASS=<re_xxxxx>
#   Mailtrap (dev sandbox): HOST=sandbox.smtp.mailtrap.io  PORT=2525
#
# If not set, emails are skipped (warning logged) — app still works normally.
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=REPLACE_WITH_SMTP_PASSWORD_OR_API_KEY
EMAIL_FROM="StuGig" <noreply@stugig.com>
